doctype html
html
    head
        meta(charset="UTF-8")
        meta(name="viewport",
            content="width=device-width, user-scalable=no, initial-scale=1.0, maximum-scale=1.0, minimum-scale=1.0")
        meta(http-equiv="X-UA-Compatible", content="ie=edge")
        include seo_meta
        link(rel="shortcut icon", href="/img/frog-profile.svg", type="image/x-icon")
        //- link(rel="icon", href="/favicon.ico", type="image/x-icon")
        block title
        link(rel="preconnect", href="https://cdn.jsdelivr.net", crossorigin="anonymous")
        link(rel="preload",
            as="style",
            crossorigin,
            href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable-dynamic-subset.css")
        link(rel="stylesheet",
            href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable-dynamic-subset.css")
        script(src="/prism/prism.js")
        link(href="/prism/prism.css", rel="stylesheet")
        link(href="/css/reset.css", rel="stylesheet")
        link(id="frogui-css", href="/frogui.css", rel="stylesheet")
        link(href="/css/style.css", rel="stylesheet")
        script(async, src="https://plausible.io/js/pa-PNF1ZKkVWIqCuHg5qB1bO.js")
        script.
            window.plausible = window.plausible || function() { (plausible.q = plausible.q || []).push(arguments) };
            plausible.init = plausible.init || function(i) { plausible.o = i || {} };
            
            // Plausible 스크립트가 로드된 후 초기화
            document.addEventListener('DOMContentLoaded', function() {
                if (typeof plausible !== 'undefined') {
                    plausible.init();
                }
            });
    body
        .root
            header.gnb
                .header-wrapper.container.center
                    nav.main-menu
                         if error || title !== 'Frog UI'
                            .toggle-menu
                                .ga-button.icon.round.show-menu
                                    i.xi-bars
                    .logo 
                        a(href="/")
                            svg( width="60", height="60", viewBox="0 0 60 60", fill="none", xmlns="http://www.w3.org/2000/svg")
                                path(d="M8 12C8 9.79086 9.79086 8 12 8H24.6667C26.5076 8 28 9.49238 28 11.3333V11.3333C28 20.5381 20.5381 28 11.3333 28V28C9.49238 28 8 26.5076 8 24.6667V12Z", fill="currentColor")
                                path(d="M36 28C33.7909 28 32 26.2091 32 24L32 11.3333C32 9.49238 33.4924 8 35.3333 8V8C44.5381 8 52 15.4619 52 24.6667V24.6667C52 26.5076 50.5076 28 48.6667 28L36 28Z", fill="currentColor")
                                path(d="M32 36C32 33.7909 33.7909 32 36 32H48C50.2091 32 52 33.7909 52 36V48C52 50.2091 50.2091 52 48 52H36C33.7909 52 32 50.2091 32 48V36Z", fill="currentColor")
                            span FROG
                        //- div.sub-logo Fix, Refactor, Optimize, Grow!!
                        //- div.sub-logo Frontend Renders On Grid...
                        //- div.sub-logo For Real, Only Good!!
                    nav.sub-menu.small
                        .locale
                            .ga-button.round
                        .buttons-part
                            .ga-button.round.badge.compact
                                | Be-UI 
                                .in-badge.ga-deepblue React
                                a.link(href="https://react-be-ui.vercel.app/", target="_blank")
                            .ga-button.round.badge.compact
                                | Be-UI 
                                .in-badge.ga-green vue
                                a.link(href="https://beui.vercel.app/", target="_blank") 
                        
                            .mode
                                .ga-button.icon.round.toggle-mode
                                    i.xi-sun-o
                            .github
                                a.ga-button.icon.round.toggle-mode(href="https://github.com/noistommy/frog-ui-css", target="_blank")
                                    i.xi-github
                        .more 
                            .ga-button.icon.round.toggle-sub
                                i.xi-ellipsis-h
                        

            if !error && title === 'Frog UI'
                .main-container.main
                    .right-part
                        block contents
            else     
                .main-container.main.container.center
                    .left-part
                        .side-menu
                            include lnb
                    .right-part
                        block contents
        block module
        block js-module
        
        script(src="/base.js")
        script(src="/js/css-switcher.js")
        script.
            window.va = window.va || function () { (window.vaq = window.vaq || []).push(arguments); };
        script(defer, src="/_vercel/insights/script.js")
       

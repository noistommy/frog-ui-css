extends ../layout

block title
    title #{title} | Frog UI CSS

block contents
    .page-wrapper
        section#tabs
            .section-title
                h1= title
                .section-desc 
                    p !{cont("ELEMENTS_SEGMENTS_SUB_TITLE")}
            .section-contents
                h4.contents-title 기본
                .ga-segment.float.round-m.attached
                    .contents-wrapper.contents
                        .ga-segment
                            .contents
                                | Contents 영역         
                        .ga-segment.border
                            .contents
                                | Contents 영역         
                    .footer
                        .code-wrapper
                            pre
                                code.language-markup= codes.code_1_1
            .section-contents
                h4.contents-title Border
                .ga-segment.float.round-m.attached
                    .contents-wrapper.contents    
                        .ga-segment.border
                            .contents
                                | Contents 영역         
                    .footer
                        .code-wrapper
                            pre
                                code.language-markup= codes.code_2_1
            .section-contents
                h4.contents-title Float
                .ga-segment.float.round-m.attached
                    .contents-wrapper.contents    
                        .ga-segment.float
                            .contents
                                | Contents 영역         
                    .footer
                        .code-wrapper
                            pre
                                code.language-markup= codes.code_3_1
            .section-contents
                h4.contents-title Surface
                .ga-segment.float.round-m.attached
                    .contents-wrapper.contents    
                        .ga-segment.surface
                            .contents
                                | Contents 영역         
                    .footer
                        .code-wrapper
                            pre
                                code.language-markup= codes.code_4_1
            .section-contents
                h4.contents-title Align
                .ga-segment.float.round-m.attached
                    .contents-wrapper.contents 
                        .ga-segment.border.align-left
                            .contents
                                | Left Align Contents 영역         
                        .ga-segment.border.align-center
                            .contents
                                | Center Align Contents 영역         
                        .ga-segment.border.align-right
                            .contents
                                | Right Align Contents 영역         
                    .footer
                        .code-wrapper
                            pre
                                code.language-markup= codes.code_5_1
                                code.language-markup= codes.code1_5_1
                                code.language-markup= codes.code2_5_1
            .section-contents
                h4.contents-title Round
                .ga-segment.float.round-m.attached
                    .contents-wrapper.contents 
                        .ga-segment.border.round-s
                            .contents
                                .title round S         
                                | Contents 영역         
                        .ga-segment.border.round-m
                            .contents
                                .title round M
                                | Contents 영역         
                        .ga-segment.border.round-l
                            .contents
                                .title round L
                                | Contents 영역         
                        .ga-segment.border.round-xl
                            .contents
                                .title round XL
                                | Contents 영역         
                    .footer
                        .code-wrapper
                            pre
                                code.language-markup= codes.code_6_1
            .section-contents
                h4.contents-title Title
                .ga-segment.float.round-m.attached
                    .contents-wrapper.contents
                        .ga-segment.border
                            .contents
                                .title.h1 Title
                                | Contents 영역
                    .footer 
                        .code-wrapper
                            pre
                                code.language-markup= codes.code_7_1
            .section-contents
                h4.contents-title Attached (header, footer)
                .ga-segment.float.round-m.attached
                    .contents-wrapper.contents
                        .ga-segment.border.attached 
                            .header 
                                .title Header 영역
                            .contents Contents 영역
                            .footer Footer 영역
                    .footer 
                        .code-wrapper
                            pre
                                code.language-markup= codes.code_8_1
            .section-contents
                h4.contents-title Segments
                .ga-segment.float.round-m.attached
                    .contents-wrapper.contents
                        .ga-segments.border.round-m
                            .ga-segment.border
                                .contents
                                    .title Segment 1
                                    | Contents 영역         
                            .ga-segment.border
                                .contents
                                    .title Segment 2
                                    | Contents 영역         
                    .footer
                        .code-wrapper
                            pre
                                code.language-markup= codes.code_9_1
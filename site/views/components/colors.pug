extends ../layout

block title
    title #{title} | Frog UI CSS

block contents
    .page-wrapper
        section#typography
            .section-title
                h1= title
                .section-desc
                    p !{cont("BASE_COLORS_SUB_TITLE")}
            .section-contents
                h4.contents-title Brands
                .ga-segment.float.round-m.attached
                    .contents-wrapper
                        .color-box.primary Primary
                        .color-box.primary.dark Darker
                    .contents-wrapper
                        .color-box.secondary Secondary
                        .color-box.secondary.dark Darker
                    .footer
                        - var code_p = `<div class="primary">Primary</div>`
                        - var code_pd = `<div class="primary dark">Primary - Darker</div>`
                        - var code_s = `<div class="secondary">Secondary</div>`
                        - var code_sd = `<div class="secondary dark">Secondary - Darker</div>`
                        pre 
                            code.language-markup 
                                | #{code_p}
                                |   #{code_pd}
                                |   #{code_s}
                                |   #{code_sd}

            .section-contents
                h4.contents-title Status
                .ga-segment.float.round-m.attached
                    .contents-wrapper
                        .color-box.ga-success Success
                        .color-box.ga-info Info
                        .color-box.ga-danger Danger
                        .color-box.ga-attention Attention
                        .color-box.ga-importance Importance
                    .contents-wrapper
                        .color-box.ga-success-light Success
                        .color-box.ga-info-light Info
                        .color-box.ga-danger-light Danger
                        .color-box.ga-attention-light Attention
                        .color-box.ga-importance-light Importance
                    .footer
                        - var code_state_succ = '<div class="ga-success">Success</div>'
                        - var code_state_info = '<div class="ga-info">Info</div>'
                        - var code_state_dang = '<div class="ga-danger">Danger</div>'
                        - var code_state_atte = '<div class="ga-attention">Attention</div>'
                        - var code_state_impo = '<div class="ga-importance">Importance</div>'
                        pre 
                            code.language-markup 
                                |
                                | #{code_state_succ}
                                | #{code_state_info}
                                | #{code_state_dang}
                                | #{code_state_atte}
                                | #{code_state_impo}
            .section-contents
                h4.contents-title Types
                .ga-segment.float.round-m.attached
                    .contents-wrapper
                        .color-box.ga-primary.bordered Basic
                        .color-box.ga-primary-text Text
                        .color-box.ga-primary-bg Background
                        .color-box.ga-primary-light Light
                        .color-box.bordered.ga-primary-border Border
                    .contents-wrapper
                        .color-box.ga-success.bordered Basic
                        .color-box.ga-success-text Text
                        .color-box.ga-success-bg Background
                        .color-box.ga-success-light Light
                        .color-box.bordered.ga-success-border Border
                    .footer 
                        - var code_type = `// @type: primary | secondary | success | info | ...`
                        - var code_type_base = '<div class="ga-{type}">Basic</div>'
                        - var code_type_text = '<div class="ga-{type}-text">Text</div>'
                        - var code_type_bg = '<div class="ga-{type}-bg">Background</div>'
                        - var code_type_light = '<div class="ga-{type}-light">Light</div>'
                        - var code_type_brd = '<div class="ga-{type}-border">Border</div>'
                        pre 
                            code.language-markup 
                                |
                                | #{code_type}
                                | #{code_type_base}
                                | #{code_type_text}
                                | #{code_type_bg}
                                | #{code_type_light}
                                | #{code_type_brd}
            .section-contents
                h4.contents-title Grayscale
                .ga-segment.float.round-m.attached
                    .contents-wrapper
                        .color-box.small.gray-bg-0 White (0)
                        .color-box.small.gray-bg-5 5
                        .color-box.small.gray-bg-10 10
                        .color-box.small.gray-bg-15 15
                        .color-box.small.gray-bg-20 20
                        .color-box.small.gray-bg-30 30
                        .color-box.small.gray-bg-40 40
                        .color-box.small.gray-bg-50 50
                        .color-box.small.gray-bg-60 60
                        .color-box.small.gray-bg-70 70
                        .color-box.small.gray-bg-80 80
                        .color-box.small.gray-bg-85 85
                        .color-box.small.gray-bg-90 90
                        .color-box.small.gray-bg-95 95
                        .color-box.small.gray-bg-100 Black (100)
                    .footer 
                        - var code_type_colors = '<!-- grays = [0, 5, 10, 15, 20, 30, 40, 50, 60, 70, 80, 85, 90, 95, 100] -->'
                        - var code_type_color_0 = '<div class="gray-bg-0">...</div>'
                        - var code_type_color_100 = '<div class="gray-bg-100">...</div>'
                        pre 
                            code.language-markup 
                                |
                                | #{code_type_colors}
                                | #{code_type_color_0}
                                | ...
                                | #{code_type_color_100}
            .section-contents
                h4.contents-title Palette Colors
                .ga-segment.float.round-m.attached
                    .contents-wrapper
                        - var colors = [{name: 'red', text: '빨강'},{name: 'orange', text: '주황'},{name: 'yellow', text: '노랑'},{name: 'lightgreen', text: '연두'},{name: 'green', text: '초록'},{name: 'lightblue', text: '하늘'},{name: 'blue', text: '파랑'},{name: 'deepblue', text: '짙은파랑'},{name: 'deeppurple', text: '짙은보라'},{name: 'purple', text: '보라'},{name: 'brown', text: '팥색'},{name: 'gray', text: '회색'}]
                        each color in colors
                            div(class=`color-box ga-${color.name} bordered`)=color.name
                    .footer 
                        - var code_type_colors = '<!-- colors = [red, orange, yellow, lightgreen, green, lightblue, blue, deepblue, deeppurple, brown, gray] -->'
                        - var code_type_color_red = '<div class="ga red">...</div>'
                        - var code_type_color_orange = '<div class=" ga orange">...</div>'
                        pre 
                            code.language-markup 
                                |
                                | #{code_type_colors}
                                | #{code_type_color_red}
                                | #{code_type_color_orange}
                                | ...
                                
extends ../layout

block title
    title #{title} | Frog UI CSS

block contents
    .page-wrapper
        section#grid
            .section-title
                h1= title
                .section-desc
                    p !{cont("LAYOUT_GRID2_SUB_TITLE")}
            .section-contents
                h4.contents-title Base
                .ga-segment.float.round-m.attached
                    .contents-wrapper
                        .ga-grid2.divide-column-8.row-2
                            each col in [1, 2, 3, 4, 5, 6]
                                .column
                            each col in [1, 2, 3, 4, 5, 6]
                                .column
                    .footer
                        pre
                            code.language-markup
                                | #{codes.base}
            .section-contents
                h4.contents-title Dosirak
                .ga-segment.float.round-m.attached
                    .contents-wrapper
                        .ga-grid2.dosirak.set-rows(style="--grid-col-num: 4; --grid-row-num: 3; --rows-height: 10rem")
                            each col in [[2, 1],[1, 1],[1, 2],[1, 1],[2, 1],]
                                .column(class=`col-${col[0]} row-${col[1]}`)
                    .footer
                        pre
                            code.language-markup
                                | #{codes.base}
            .section-contents
                h4.contents-title Divide
                .ga-segment.float.round-m.attached
                    .contents-wrapper
                        .ga-grid2
                            .column.col-1
                            .column.col-3
                            .column.col-1
                            .column.col-3
                            .column.col-1
                            .column.col-3
                            .column.col-1
                            .column.col-3
                            .column.col-1
                            .column.col-3
                            .column.col-1
                            .column.col-3
                    .footer
                        pre
                            code.language-markup
                                | #{codes.divide}
            .section-contents
                h4.contents-title Divide (+ROW)
                .ga-segment.float.round-m.attached
                    .contents-wrapper
                        .ga-grid2.set-rows(style="--grid-row-num: 9")
                            .column.col-6.row-6
                            .column.col-6.row-4
                            .column.col-6.row-2
                            .column.col-12
                            .column.col-6.row-2
                            .column.col-6.row-2
                            
                    .footer
                        pre
                            code.language-markup
                                | #{codes.divideRow}
            .section-contents
                h4.contents-title Auto-fit
                .ga-segment.float.round-m.attached
                    .contents-wrapper
                        .ga-grid2.divide-column-10.auto-fit
                            .column
                            .column
                            .column
                            .column
                    .footer
                        pre
                            code.language-markup
                                | #{codes.autoFit}
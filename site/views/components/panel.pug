            //- .section-contents
                h4.contents-title Example
                .ga-segment.float.round-m.attached
                    .contents-wrapper
                        .ga-panel.open
                            .panel-header
                                .title Title
                            .panel-content
                                .content-wrapper
                                    .header Student List
                                    .body
                                        - var rows = [{name: 'John Doe', age: 11, job: 'Student'},{name: 'Jane Roe', age: 17, job: 'College Student'},{name: 'Alex Kim', age: 31, job: 'Graduate Student'},]
                                        table.ga-table
                                            thead
                                                tr.align-center
                                                    th Name
                                                    th.align-right Age
                                                    th Job
                                            tbody
                                                each row in rows
                                                    tr
                                                        td= `${row.name}`
                                                        td.align-right= `${row.age}`
                                                        td= `${row.job}`
                                    .footer
                                        .ga-pagination.number.align-center.small
                                            - var items = [2, 3, 4, 5]
                                            .pagination-nav
                                                i.xi-angle-left
                                            .pagination-page-wrapper
                                                .pagination-num.active 1
                                                each item in items
                                                    .pagination-num=`${item}`
                                            .pagination-nav
                                                i.xi-angle-right

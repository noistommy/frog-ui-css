extends ../layout

block title
    title #{title} | Frog UI CSS

block contents
    .page-wrapper
        section#switch
            .section-title
                h1= title
                .section-desc 
                    p !{cont("ELEMENTS_SWITCH_SUB_TITLE")}
            .section-contents
                h4.contents-title Base 1
                .ga-segment.float.round-m.attached
                    .contents-wrapper
                        label.ga-switch.slide
                            input(type="checkbox", checked)
                            span.switch
                    .footer
                        pre
                            code.language-markup
                                | #{codes.base1}
            .section-contents
                h4.contents-title Base 2
                .ga-segment.float.round-m.attached
                    .contents-wrapper
                        label.ga-switch.slide.inside
                            input(type="checkbox", checked)
                            span.switch
                    .footer
                        pre
                            code.language-markup
                                | #{codes.base2}
            .section-contents
                h4.contents-title Round
                .ga-segment.float.round-m.attached
                    .contents-wrapper
                        label.ga-switch.slide.inside.round
                            input(type="checkbox", checked)
                            span.switch
                    .contents-wrapper
                        label.ga-switch.slide.round
                            input(type="checkbox", checked)
                            span.switch
                    .footer
                        pre
                            code.language-markup
                                | #{codes.round}
            .section-contents
                h4.contents-title Button
                .ga-segment.float.round-m.attached
                    .contents-wrapper
                        label.ga-switch.button
                            input(type="checkbox", checked)
                            span.on.active ON
                            span.off OFF
                    .contents-wrapper
                        label.ga-switch.button.round
                            input(type="checkbox", checked)
                            span.on.active Yes
                            span.off No
                    .footer
                        pre
                            code.language-markup
                                | #{codes.button}
            .section-contents
                h4.contents-title Colors
                .ga-segment.float.round-m.attached
                    .contents-wrapper
                        .ga.flex.gap-2
                            -
                                var colors = [
                                    {name: 'red', text: '빨강'},
                                    {name: 'orange', text: '주황'},
                                    {name: 'yellow', text: '노랑'},
                                    {name: 'lightgreen', text: '연두'},
                                    {name: 'green', text: '초록'},
                                    {name: 'lightblue', text: '하늘'},
                                    {name: 'blue', text: '파랑'},
                                    {name: 'deepblue', text: '짙은파랑'},
                                    {name: 'deeppurple', text: '짙은보라'},
                                    {name: 'purple', text: '보라'},
                                    {name: 'brown', text: '팥색'},
                                    {name: 'gray', text: '회색'}];
                            each color in colors 
                                label.ga-switch.slide.inside.round(class=`${color.name}`)
                                    input(type="checkbox", checked)
                                    span.switch 
                    .footer
                        pre
                            code.language-markup
                                | #{codes.colors}
extends ../layout

block title
    title #{title} | Frog UI CSS

block contents
    .page-wrapper
        section#tabs
            .section-title
                h1= title
                .section-desc 
                    p !{cont("ELEMENTS_TABS_SUB_TITLE")}
            .section-contents
                h4.contents-title Base
                .ga-segment.float.round-m.attached
                    .contents-wrapper
                        .ga-tabs
                            .tab-menu
                                .tab-item.tab.active Item 1
                                .tab-item.tab Item 2
                                .tab-item.tab Item 3
                                .tab-item.tab Item 4
                                .tab-item.tab Item 5
                    .footer
                        pre.code-wrapper
                            code.language-markup 
                                | #{codes.base}
            .section-contents
                h4.contents-title Vertical
                .ga-segment.float.round-m.attached
                    .contents-wrapper
                        .ga-tabs.vertical
                            .tab-menu
                                .tab-item.tab.active Item 1
                                .tab-item.tab Item 2
                                .tab-item.tab Item 3
                    .footer
                        pre.code-wrapper
                            code.language-markup 
                                | #{codes.vertical}
            .section-contents
                h4.contents-title Active (Line)
                .ga-segment.float.round-m.attached
                    .contents-wrapper
                        .ga-tabs.line
                            .tab-menu
                                .tab-item.tab.active Item 1
                                .tab-item.tab Item 2
                                .tab-item.tab Item 3
                                .tab-item.tab Item 4
                                .tab-item.tab Item 5
                    .contents-wrapper
                        .ga-tabs.line.vertical
                            .tab-menu
                                .tab-item.tab.active Item 1
                                .tab-item.tab Item 2
                                .tab-item.tab Item 3
                    .footer
                        pre.code-wrapper
                            code.language-markup 
                                | #{codes.line}
            .section-contents
                h4.contents-title Active (Button)
                .ga-segment.float.round-m.attached
                    .contents-wrapper
                        .ga-tabs.button
                            .tab-menu
                                .tab-item.tab.active Item 1
                                .tab-item.tab Item 2
                                .tab-item.tab Item 3
                                .tab-item.tab Item 4
                                .tab-item.tab Item 5
                            .tab-contents
                                | tab contents
                    .footer
                        pre.code-wrapper
                            code.language-markup 
                                | #{codes.button}
            .section-contents
                h4.contents-title Browser Tab
                .ga-segment.float.round-m.attached
                    .contents-wrapper
                        .ga-tabs.browser
                            - var tabMenu = [1, 2, 3, 4, 5]
                            .tab-menu
                                each tab in tabMenu
                                    .tab-item.tab
                                        span.tabText.ellipsis=`Item ${tab}`
                                        .btn-close.ga-button.icon.tiny.round
                                            i.xi-close
                            .tab-contents
                                .tab-plus.ga-button.icon.primary ADD
                                    i.icon.right.xi-plus
                    .footer
                        pre.code-wrapper
                            code.language-markup 
                                | #{codes.browser}
block module 
    script(src="/js/tabs.js")
